# Copy Phase 1 vars into server/.env (server/.env is gitignored).
# See server/db/migrations/ for manual migration steps against Supabase.

# --- Phase 1 (required) ---

# Supabase PostgreSQL connection string (URI format)
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Express server port (default 3000)
PORT=3000

# Set to true for local stub testing without OAuth sessions
SKIP_AUTH=true

# --- Phase 5 (Auth — not required until Phase 5) ---

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# SESSION_SECRET=

# --- Deploy (optional) ---

# NODE_ENV=production
