# Copy into server/.env (server/.env is gitignored).
# See server/db/migrations/ for manual migration steps.

# --- Required ---

# PostgreSQL connection string (URI format)
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Express server port (default 3000)
PORT=3000

# Public backend URL (used for Google OAuth callback)
API_URL=http://localhost:3000

# Frontend URL (CORS + OAuth redirects after login/logout)
CLIENT_URL=http://localhost:5173

# --- Phase 5 Auth (required) ---

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=

# --- Deploy (production) ---

# NODE_ENV=production
