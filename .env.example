# Copy into server/.env (server/.env is gitignored).
# See server/db/migrations/ for manual migration steps.

# --- Required ---

# Supabase PostgreSQL connection string (URI format)
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Express server port (default 3000)
PORT=3000

# --- Phase 5 Auth (required) ---

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=

# --- Deploy (optional) ---

# NODE_ENV=production
